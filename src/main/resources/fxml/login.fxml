<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Car Manager" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
    <Label text="Porfavor registrate para acceder" style="-fx-font-size: 14px; -fx-text-fill: gray;"/>

    <TextField fx:id="usernameField" promptText="Usuario" maxWidth="250" prefHeight="35"/>
    <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="250" prefHeight="35"/>

    <Button fx:id="loginButton" text="Login" prefWidth="250" prefHeight="35" style="-fx-background-color: #7dc2fa; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label text="¿No tienes cuenta?" style="-fx-font-size: 12px;"/>
    <Button fx:id="goToSignUpButton" text="Sign up" prefWidth="150" prefHeight="30"/>
</VBox>